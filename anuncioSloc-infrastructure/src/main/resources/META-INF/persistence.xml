<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0">

    <persistence-unit name="AnunciosLocPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernateJpaProvider</provider>

        <!-- Entity Classes -->
        <class>pt.uan.anuncioSloc.persistence.entity.Infraestrutura</class>
        <class>pt.uan.anuncioSloc.persistence.entity.Local</class>
        <class>pt.uan.anuncioSloc.persistence.entity.Coordenada</class>
        <class>pt.uan.anuncioSloc.persistence.entity.UtilizadorInfra</class>
        <class>pt.uan.anuncioSloc.persistence.entity.Anuncio</class>
        <class>pt.uan.anuncioSloc.persistence.entity.Restricao</class>

        <properties>
            <!-- H2 Database Configuration -->
            <property name="javax.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="javax.persistence.jdbc.url" value="jdbc:h2:mem:anunciosloc;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE"/>
            <property name="javax.persistence.jdbc.user" value="sa"/>
            <property name="javax.persistence.jdbc.password" value=""/>

            <!-- Hibernate Configuration -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.use_sql_comments" value="true"/>

            <!-- Connection Pool -->
            <property name="hibernate.connection.pool_size" value="10"/>
        </properties>
    </persistence-unit>

</persistence>
